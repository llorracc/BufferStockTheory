% @local/<texname>.sty (in this paper @local/BufferStockTheory.sty) is the
% canonical home for ALL paper-specific LaTeX configuration: typography
% helpers, economics-symbol overrides, theorem environments, body-text
% vocabulary, figure scratchpads, and the per-paper hyperlink-style
% named-condition macros. Material that is part of shared infrastructure
% (e.g. econark-shortcuts.sty in @resources/) does NOT live here.
%
% New macros for this paper should be added to this file, not inline in
% body .tex files. The pre-commit hook
% (tools/git-hooks/lint-no-inline-defs.sh) enforces this for the
% published body files.

% ============================================================
% --- BEGIN PhaseB2 conditional-content macros ---
% ============================================================

% PhaseB2: alias rewrites for \ifthenelse{\boolean{Web}}{...}{...} so the
% MyST pipeline's bracket-balancer (phase 2) reduces to a substring scan.
% Each macro expands to the original \ifthenelse form, so PDF output is
% byte-identical.
\providecommand{\PDFOnly}[1]{\ifthenelse{\boolean{Web}}{}{#1}}
\providecommand{\WebOnly}[1]{\ifthenelse{\boolean{Web}}{#1}{}}
\providecommand{\BothVersions}[2]{\ifthenelse{\boolean{Web}}{#1}{#2}}

% \BSTcondref is the conditional fallback for the named-condition macros
% (\GICRaw, \RIC, ...) formerly written as \hyperlink{X}{\textrm{Y}}.
% The canonical definition lives in BufferStockTheory.tex:38-40 — the
% \provideboolean{Web} + \providecommand pair below makes standalone
% compiles (e.g. tikz figures via local-tikz.sty, which loads local.sty
% without the master preamble) self-sufficient.
\provideboolean{Web}
\providecommand{\BSTcondref}[2]{%
  \ifthenelse{\boolean{Web}}{\textsf{#2}}{\hyperlink{#1}{\textrm{#2}}}%
}

% --- END PhaseB2 conditional-content macros ---

% ============================================================
% --- BEGIN typography helpers (was bst-macros.sty / typography group) ---
% ============================================================

% \statement{<name>}: a bold/italic part-name introducer used by proofs and
% case analyses (e.g. "Step 1", "Claim", "Case A").
% from BufferStockTheory.tex:51-56 (pre-A1)
\newcommand{\statement}[1]{%
  \vspace{1em}  % Add some vertical space before the part
  \textit{#1}   % Make the part name bold (e.g., "Step 1", "Claim", "Case A")
  \enspace      % Add a little horizontal space
  \ignorespaces % Ignore spaces at the beginning of the text
}

% \headmath{<formula>}: pads a formula with extra horizontal space on each
% side, used in appendix headings.
% from Appendices/ApndxBalancedGrowthcNrmAndCov.tex:18-21 (pre-A1)
\newcommand{\headmath}[1]{%
  \settowidth{\dimen0}{$#1$}%
  \mbox{}\hspace{1.2\dimen0}$#1$\hspace{1.2\dimen0}\mbox{}%
}

% --- END typography helpers ---

