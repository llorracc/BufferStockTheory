% Macros that were previously declared inline inside paragraph bodies
% (or between body elements). Canonical defs live here as
% \providecommand so the body-side inline copies — which we deliberately
% leave in place — are no-ops. We do NOT remove the body-side copies
% because doing so subtly changes LaTeX's tokenization of the
% surrounding prose (observed: math-mode binop spacing flips, paragraph
% breaks shift). A future refactor can remove them once a
% whitespace-/token-preserving replacement strategy is verified.

% Difference function used in two stability proofs; body inline at
% Appendices/ApndxMTargetIsStable.tex:149 and :250 (mid-paragraph
% \providecommand — idempotent, so coexists with the entry below).
\providecommand{\difFunc}{\pmb{\zeta}}

% English vocabulary tag for the "growth patience factor"; body inline
% at sections/TheoreticalFoundations.tex:297 (between \hypertarget and
% prose). The body-side copy was originally \newcommand; A3-retry
% changed it to \providecommand so it coexists with this entry.
\providecommand{\GPFacRawName}{growth patience factor}

